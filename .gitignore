# ==========================================
# ROOT-LEVEL IGNORES
# ==========================================

# Dependencies (if ever installed at root)
/node_modules

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE - Root level only (subdirs handle their own)
/.idea
*.sublime-workspace

# Environment files (security critical)
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Local development files
/docker-compose.override.yml
/.env.backup
