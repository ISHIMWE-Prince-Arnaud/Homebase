# ==========================================
# REQUIRED VARIABLES
# These must be set for the application to work
# ==========================================

# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Example for local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/homebasedb
# Example for Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/homebasedb

# JWT signing secret - MUST be at least 32 characters
# Generate a secure random secret with:
#   node scripts/jwt-secret.js
# Or use any secure random string generator
JWT_SECRET=replace-with-a-random-secret-min-32-characters-long

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# HTTP port for the API server
PORT=3000

# Environment mode
# - development: Allows all CORS origins, non-secure cookies
# - production: Restricts CORS, secure cookies, stricter security
NODE_ENV=development

# ==========================================
# CORS CONFIGURATION
# ==========================================

# Allowed frontend origin for CORS
# In development, defaults to allowing all origins
# In production, this restricts which domains can access the API
FRONTEND_URL=http://localhost:5173

# ==========================================
# RATE LIMITING CONFIGURATION
# All values are in milliseconds
# ==========================================

# Short window - Strict limits for auth endpoints (login/register)
THROTTLE_TTL_SHORT=60000          # Window duration: 1 minute
THROTTLE_LIMIT_SHORT=10             # Max requests per window: 10

# Medium window - General API limits
THROTTLE_TTL_MEDIUM=900000        # Window duration: 15 minutes
THROTTLE_LIMIT_MEDIUM=100           # Max requests per window: 100

# Long window - Global hourly limit
THROTTLE_TTL_LONG=3600000         # Window duration: 1 hour
THROTTLE_LIMIT_LONG=300             # Max requests per hour: 300

# ==========================================
# JWT CONFIGURATION
# ==========================================

# JWT token expiration time in seconds
# Default: 604800 (7 days)
JWT_EXPIRATION=604800

# ==========================================
# OPTIONAL: TEST DATABASE (for running tests)
# ==========================================

# Separate database for e2e/testing to avoid data loss
# TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/homebasetestdb

# ==========================================
# NOTES
# ==========================================
#
# 1. Security headers are configured via Helmet middleware
#    and don't require environment variables by default.
#    See: src/common/security/helmet.config.ts
#
# 2. Cookie security:
#    - httpOnly: always enabled (prevents XSS)
#    - secure: enabled in production (HTTPS only)
#    - sameSite: 'none' in production, 'lax' in dev
#
# 3. Prisma configuration is in prisma.config.ts
#    It reads DATABASE_URL from this file automatically.
