# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/homebasedb

# JWT
JWT_SECRET=replace-with-a-random-secret-min-32-chars

# Server
PORT=3000
NODE_ENV=development

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# CORS - Comma-separated allowed origins
FRONTEND_URL=http://localhost:5173

# Rate Limiting (values in milliseconds)
THROTTLE_TTL_SHORT=60000          # 1 minute window for auth
THROTTLE_LIMIT_SHORT=10             # 10 requests per window
THROTTLE_TTL_MEDIUM=900000        # 15 minute window for general API
THROTTLE_LIMIT_MEDIUM=100           # 100 requests per window
THROTTLE_TTL_LONG=3600000         # 1 hour global window
THROTTLE_LIMIT_LONG=300             # 300 requests per hour

# Security Headers
# (Configured via helmet - no env vars needed by default)

# JWT Expiration (seconds)
JWT_EXPIRATION=604800             # 7 days
