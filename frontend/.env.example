# ==========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# Copy this file to .env and update values as needed
# ==========================================

# Backend API base URL
# This is the URL where your NestJS backend is running
# 
# For local development (default backend port):
VITE_API_URL=http://localhost:3000
#
# If your backend runs on a custom port:
# VITE_API_URL=http://localhost:4000
#
# For production (after deploying backend):
# VITE_API_URL=https://your-api-domain.com

# ==========================================
# NOTES
# ==========================================
#
# 1. Vite automatically exposes env vars prefixed with VITE_ to the client.
#    Never prefix sensitive values with VITE_.
#
# 2. This URL must match the backend's allowed CORS origins (FRONTEND_URL).
#    If you change this, update backend .env FRONTEND_URL accordingly.
#
# 3. The API client is configured in src/api/client.ts
#    It uses withCredentials: true for httpOnly cookie support.
#
# 4. After changing this file, restart the dev server:
#    npm run dev
